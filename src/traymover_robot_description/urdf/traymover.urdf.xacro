<?xml version="1.0"?>
<robot name="traymover" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="body_length" value="0.80"/>
  <xacro:property name="body_width" value="0.55"/>
  <xacro:property name="body_height" value="0.24"/>
  <xacro:property name="body_center_z" value="0.20"/>

  <xacro:property name="wheel_radius" value="0.085"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_y_offset" value="0.2275"/>
  <xacro:property name="wheel_z_offset" value="-0.085"/>

  <xacro:property name="caster_radius" value="0.04"/>
  <xacro:property name="caster_front_x" value="0.32"/>
  <xacro:property name="caster_rear_x" value="-0.32"/>
  <xacro:property name="caster_y_offset" value="0.195"/>
  <xacro:property name="caster_z_offset" value="-0.16"/>

  <xacro:property name="mast_thickness" value="0.05"/>
  <xacro:property name="mast_width" value="0.155"/>
  <xacro:property name="mast_height" value="1.20"/>
  <xacro:property name="mast_x" value="0.375"/>
  <xacro:property name="mast_z" value="0.71"/>

  <xacro:property name="lidar_radius" value="0.06"/>
  <xacro:property name="lidar_height" value="0.11"/>
  <xacro:property name="lidar_x" value="0.375"/>
  <xacro:property name="lidar_z" value="1.365"/>

  <xacro:property name="camera_mount_length" value="0.10"/>
  <xacro:property name="camera_mount_width" value="0.08"/>
  <xacro:property name="camera_mount_thickness" value="0.01"/>
  <xacro:property name="camera_mount_x" value="0.45"/>
  <xacro:property name="camera_mount_z" value="0.745"/>

  <xacro:property name="camera_depth" value="0.025"/>
  <xacro:property name="camera_width" value="0.10"/>
  <xacro:property name="camera_height" value="0.025"/>
  <xacro:property name="camera_z_from_mount" value="0.015"/>
  <xacro:property name="imu_marker_length" value="0.08"/>
  <xacro:property name="imu_marker_width" value="0.04"/>
  <xacro:property name="imu_marker_height" value="0.02"/>

  <material name="traymover_gray">
    <color rgba="0.28 0.31 0.34 1.0"/>
  </material>

  <material name="traymover_black">
    <color rgba="0.10 0.10 0.10 1.0"/>
  </material>

  <material name="traymover_silver">
    <color rgba="0.75 0.77 0.80 1.0"/>
  </material>

  <material name="traymover_blue">
    <color rgba="0.20 0.42 0.76 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="traymover_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.01" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
  </link>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${imu_marker_length} ${imu_marker_width} ${imu_marker_height}"/>
      </geometry>
      <material name="traymover_blue"/>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 ${-body_height / 2.0}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>

  <xacro:macro name="drive_wheel" params="name x y z axis_y">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="traymover_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="${name}"/>
      <axis xyz="0 ${axis_y} 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="caster_wheel" params="name x y z">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="traymover_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_joint" type="fixed">
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="${name}"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel
    name="left_wheel_link"
    x="0.0"
    y="${wheel_y_offset}"
    z="${wheel_z_offset}"
    axis_y="1"/>

  <xacro:drive_wheel
    name="right_wheel_link"
    x="0.0"
    y="${-wheel_y_offset}"
    z="${wheel_z_offset}"
    axis_y="-1"/>

  <xacro:caster_wheel
    name="front_left_caster_link"
    x="${caster_front_x}"
    y="${caster_y_offset}"
    z="${caster_z_offset}"/>

  <xacro:caster_wheel
    name="front_right_caster_link"
    x="${caster_front_x}"
    y="${-caster_y_offset}"
    z="${caster_z_offset}"/>

  <xacro:caster_wheel
    name="rear_left_caster_link"
    x="${caster_rear_x}"
    y="${caster_y_offset}"
    z="${caster_z_offset}"/>

  <xacro:caster_wheel
    name="rear_right_caster_link"
    x="${caster_rear_x}"
    y="${-caster_y_offset}"
    z="${caster_z_offset}"/>

  <link name="sensor_mast_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_thickness} ${mast_width} ${mast_height}"/>
      </geometry>
      <material name="traymover_silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_thickness} ${mast_width} ${mast_height}"/>
      </geometry>
    </collision>
  </link>

  <joint name="sensor_mast_joint" type="fixed">
    <origin xyz="${mast_x} 0 ${mast_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="sensor_mast_link"/>
  </joint>

  <link name="laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="traymover_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0.06 0 ${lidar_z - mast_z}" rpy="0 0 0"/>
    <parent link="sensor_mast_link"/>
    <child link="laser"/>
  </joint>

  <link name="camera_mount_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_mount_length} ${camera_mount_width} ${camera_mount_thickness}"/>
      </geometry>
      <material name="traymover_silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_mount_length} ${camera_mount_width} ${camera_mount_thickness}"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <origin xyz="${camera_mount_x} 0 ${camera_mount_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_mount_link"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_depth} ${camera_width} ${camera_height}"/>
      </geometry>
      <material name="traymover_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_depth} ${camera_width} ${camera_height}"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0 0 ${camera_z_from_mount}" rpy="0 0 0"/>
    <parent link="camera_mount_link"/>
    <child link="camera_link"/>
  </joint>
</robot>
